# Archmind environment. Copy to .env and fill in.

# --- Auth ---
# Sign/verify session JWTs. Must be a long, random, unguessable string in production.
JWT_SECRET=

# Encrypts GitHub OAuth tokens (and user-supplied Gemini keys) at rest.
# Must be EXACTLY 32 raw ASCII bytes/characters (AES-256-GCM key). Generate with:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex') + require('crypto').randomBytes(16).toString('hex'))"
# (Any 32-character string works; the point is it must be exactly 32 characters, not
# a 32-character hex/base64 *encoding* of a shorter key.)
ENCRYPTION_KEY=

# --- GitHub OAuth App (github.com/settings/developers) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public URL this app is served from (used to build the OAuth redirect_uri).
BASE_URL=http://localhost:3000

# --- Database (Postgres via Prisma; see docker-compose.yml for local dev) ---
DATABASE_URL=postgresql://archmind:archmind@localhost:5432/archmind

# --- AI ---
# Optional: server-side fallback Gemini key used when a user hasn't supplied their own
# (via the per-user geminiKey field). If unset, /api/v1/analyses returns a simulated
# result instead of calling Gemini. Note: Gemini's free tier does not carry a
# zero-data-retention/no-training guarantee — see Privacy Policy before using it on
# real user repositories at scale.
GEMINI_API_KEY=

# --- Rate limiting (Upstash Redis) ---
# Optional but strongly recommended before public launch — without these, rate
# limiting on /api/v1/analyses and other GitHub-calling routes is disabled (a warning
# is logged at build/boot time when they're unset).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
