# Atlas environment (see PROJECT_HANDOFF.md §16). Copy to .env and fill in.
# The Phase-0 ingestion spike runs with ZERO of these set (it uses a mock embedder
# and a local JSON store). Set VOYAGE_API_KEY to switch the spike to real embeddings.

# --- AI / embeddings ---
ANTHROPIC_API_KEY=
# Optional free-tier alternative to Claude (packages/agent-core/src/llm.ts). Used only
# when ANTHROPIC_API_KEY is unset, or forced via ATLAS_LLM_PROVIDER=gemini|anthropic.
# SECURITY (docs/08 T-09): the free Gemini tier has no zero-data-retention / no-training
# commitment. Prototyping/fixture data only -- do not point this at real customer repos.
GEMINI_API_KEY=
ATLAS_LLM_PROVIDER=
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-code-3
VOYAGE_RERANK_MODEL=rerank-2.5

# --- GitHub App (see docs/04) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Data stores (see docs/06) ---
DATABASE_URL=postgres://atlas:atlas@localhost:5432/atlas
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=atlas-dev
REDIS_URL=redis://localhost:6379
ZOEKT_URL=http://localhost:6070
TEMPORAL_ADDRESS=localhost:7233

# --- AWS / storage (see docs/06, 08); LocalStack for dev ---
S3_BUCKET=atlas-dev-code
S3_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
KMS_KEY_ID=

# --- Enterprise identity (see docs/08) ---
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
